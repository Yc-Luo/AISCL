# Docker Compose 服务器部署专用变量。
# 复制为项目根目录下的 .env 后，docker compose 会自动读取。

# 对外访问端口。正式域名部署一般用 80；若服务器 80 被占用，可改成 8888。
AISCL_HTTP_PORT=80

# Python 依赖安装源。若服务器访问默认 PyPI 慢或解析不到包，可改为国内镜像。
# 可选示例：https://pypi.tuna.tsinghua.edu.cn/simple 或 https://mirrors.aliyun.com/pypi/simple
PIP_INDEX_URL=https://pypi.org/simple

# 使用 docker-compose.images.yml 拉取远程镜像时生效。
# 默认 latest；如需固定版本，可填写 GitHub Actions 生成的 sha-xxxxxxx 或 v1.0.0。
AISCL_IMAGE_TAG=latest

# MinIO 容器启动所需 root 凭证。
# 必须与 backend/.env 中的 MINIO_ACCESS_KEY / MINIO_SECRET_KEY 保持一致。
MINIO_ROOT_USER=replace-minio-root-user
MINIO_ROOT_PASSWORD=replace-minio-root-password
