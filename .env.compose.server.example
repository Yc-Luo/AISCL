# Docker Compose 服务器部署专用变量。
# 复制为项目根目录下的 .env 后，docker compose 会自动读取。

# 对外访问端口。正式域名部署一般用 80；若服务器 80 被占用，可改成 8888。
AISCL_HTTP_PORT=80

# MinIO 容器启动所需 root 凭证。
# 必须与 backend/.env 中的 MINIO_ACCESS_KEY / MINIO_SECRET_KEY 保持一致。
MINIO_ROOT_USER=replace-minio-root-user
MINIO_ROOT_PASSWORD=replace-minio-root-password
