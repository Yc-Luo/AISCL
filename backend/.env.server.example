# AISCL 后端服务器部署环境变量模板
# 用法：
# 1. 复制为 backend/.env
# 2. 按实际服务器、域名和模型服务填写

APP_NAME=AISCL
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# 必填，至少 32 位
SECRET_KEY=replace-with-32-char-secret-key
JWT_SECRET_KEY=replace-with-32-char-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Docker Compose server 编排下建议保持容器内地址
MONGODB_URI=mongodb://mongodb:27017/AISCL
MONGODB_DB_NAME=AISCL
MONGODB_MAX_POOL_SIZE=10

REDIS_URL=redis://redis:6379/0

STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-minio-root-user
MINIO_SECRET_KEY=replace-minio-root-password
MINIO_BUCKET_NAME=AISCL-files

# 学生端通过 nginx 统一访问时，可写域名或公网 IP
MINIO_PUBLIC_ENDPOINT=your-domain-or-ip
MINIO_USE_SSL=false

# 当前系统建议从环境变量读取模型配置
LLM_CONFIG_SOURCE=env
LLM_PROVIDER=deepseek

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 生产环境至少填写最终访问地址
# 如启用 HTTPS，请改为 https://your-domain
CORS_ORIGINS=["http://your-domain-or-ip","https://your-domain"]

MAX_FILE_SIZE=52428800
MAX_PROJECT_STORAGE=5368709120
MAX_PROJECT_MEMBERS=5

CDN_BASE_URL=
