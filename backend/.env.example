APP_NAME=AISCL
APP_ENV=production
DEBUG=False
LOG_LEVEL=INFO
HF_HOME=/app/data/hf_cache
TRANSFORMERS_CACHE=/app/data/hf_cache
SENTENCE_TRANSFORMERS_HOME=/app/data/hf_cache
XDG_CACHE_HOME=/app/data/xdg_cache

LLM_CONFIG_SOURCE=env
LLM_PROVIDER=deepseek
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

SECRET_KEY=replace-with-at-least-32-characters
JWT_SECRET_KEY=replace-with-at-least-32-characters

MONGODB_URI=mongodb://localhost:27017/AISCL
MONGODB_DB_NAME=AISCL
REDIS_URL=redis://localhost:6379/0

STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:8888
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-minio-secret
MINIO_BUCKET_NAME=aiscl-files
MINIO_USE_SSL=False

OPENAI_API_KEY=
DEEPSEEK_API_KEY=

CORS_ORIGINS=["http://localhost:3000","http://localhost:8888","http://127.0.0.1:8888"]
