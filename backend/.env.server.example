# AISCL 后端服务器部署环境变量模板
# 用法：
# 1. 复制为 backend/.env
# 2. 按实际服务器、域名和模型服务填写

APP_NAME=AISCL
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# 必填，至少 32 位
SECRET_KEY=replace-with-32-char-secret-key
JWT_SECRET_KEY=replace-with-32-char-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Docker Compose server 编排下建议保持容器内地址
MONGODB_URI=mongodb://mongodb:27017/AISCL
MONGODB_DB_NAME=AISCL
MONGODB_MAX_POOL_SIZE=10

REDIS_URL=redis://redis:6379/0

STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-minio-root-user
MINIO_SECRET_KEY=replace-minio-root-password
MINIO_BUCKET_NAME=aiscl-files

# 学生端通过 nginx 统一访问时，可写域名或公网 IP；不要带 http(s)://、路径或 :9000
MINIO_PUBLIC_ENDPOINT=your-domain-or-ip
MINIO_USE_SSL=false

# 服务器实验环境建议使用管理员端数据库配置。
# 首次启动可先填一组可用默认值；之后在管理员端“系统配置”中调整。
LLM_CONFIG_SOURCE=db
LLM_PROVIDER=openai_compatible

OPENAI_API_KEY=
OPENAI_MODEL=MiniMax-M2.7
OPENAI_BASE_URL=https://api.minimaxi.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# RAG / LLM Wiki
RAG_VECTOR_ENABLED=true
EMBEDDING_PROVIDER=minimax
# Optional env fallback. Admin panel key `embedding_key` takes precedence.
# If both are empty, MiniMax embedding falls back to OPENAI_API_KEY.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_EMBEDDING_MODEL=embo-01
MINIMAX_EMBEDDING_BASE_URL=https://api.minimax.chat/v1/embeddings
MINIMAX_EMBEDDING_TYPE=db
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=aiscl_rag
QDRANT_VECTOR_SIZE=4096
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# Keep off during teaching experiments unless dashboard LLM summaries are needed.
ANALYTICS_LLM_ENABLED=false

# 生产环境至少填写最终访问地址
# 如启用 HTTPS，请改为 https://your-domain
CORS_ORIGINS=["http://your-domain-or-ip","https://your-domain"]

MAX_FILE_SIZE=52428800
MAX_PROJECT_STORAGE=5368709120
MAX_PROJECT_MEMBERS=5

CDN_BASE_URL=
